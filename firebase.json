{
  "firestore": {
    "database": "ai-studio-13222500-ae8c-4550-8b61-6f7dce0d48f6",
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "emailPassword": true
    }
  },
  "functions": {
    "source": "functions"
  }
}
